@model ErrorViewModel
@{
    ViewData["Title"] = "Launch Failure";
}

<section class="error-page">
    <div class="error-page__rocket-emoji" aria-hidden="true">🚀</div>

    @if (Model.ShowRequestId)
    {
        <p class="error-page__request-id">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Items" asp-action="Index" class="btn btn-primary">Return Home</a>
</section>
